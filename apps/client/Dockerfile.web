FROM nginx:alpine
ARG BUILD_ID=unknown
ARG APP_VERSION=dev
LABEL build_id=$BUILD_ID
COPY build/web/ /usr/share/nginx/html/
RUN echo "$APP_VERSION" > /usr/share/nginx/html/version.txt
COPY nginx.conf /etc/nginx/conf.d/default.conf

# nginx:alpine runs the master as root by default; switching to USER nginx
# requires the worker to be able to write its temp/cache dirs and PID file.
# Without these chowns the container fails to start unless the compose
# service overrides with `user: root`. Chowning here makes the image
# self-contained and correct out of the box.
RUN chown -R nginx:nginx \
        /var/cache/nginx \
        /var/log/nginx \
        /usr/share/nginx/html \
 && touch /var/run/nginx.pid \
 && chown nginx:nginx /var/run/nginx.pid

USER nginx
EXPOSE 80
