DATABASE_URL=postgres://echo:dev_password@localhost:5432/echo_dev
JWT_SECRET=dev-secret-change-in-production
RUST_LOG=echo_server=debug
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# iOS Push Notifications (APNs) -- optional, leave unset to disable
# See docs/ios-push-setup.md for setup instructions.
# APNS_AUTH_KEY_BASE64=   # base64-encoded .p8 key (preferred over file path)
# APNS_AUTH_KEY_PATH=     # alternative: path to .p8 file on disk
# APNS_KEY_ID=            # 10-char Key ID from Apple Developer portal
# APNS_TEAM_ID=           # 10-char Team ID from Apple Developer portal
# APNS_TOPIC=us.echomessenger.app  # your iOS bundle ID
